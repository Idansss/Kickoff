// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String
  handle    String    @unique
  avatar    String
  bio       String?
  followers Int       @default(0)
  following Int       @default(0)
  createdAt DateTime  @default(now())

  posts    Post[]
  likes    Like[]
  reposts  UserRepost[]
  messages Message[]
  follows  Follow[]
  notificationPrefs   NotificationPref[]
  pushSubscriptions   PushSubscription[]
  forumSubscriptions  ForumThreadSubscription[]
  valueQuizAttempts   ValueQuizAttempt[]
}

model Post {
  id        String   @id @default(cuid())
  content   String
  image     String?
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  likes     Like[]
  reposts   UserRepost[]
  shares    Int      @default(0)
  createdAt DateTime @default(now())

  relatedMatchId  String?
  relatedPlayerId String?

  parentId  String?
  parent    Post?    @relation("PostReplies", fields: [parentId], references: [id])
  replyList Post[]   @relation("PostReplies")
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model UserRepost {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model Message {
  id        String   @id @default(cuid())
  roomId    String
  content   String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
}

model Competition {
  id          String   @id @default(cuid())
  providerKey String?  @unique
  name        String
  country     String?
  type        String?
  logoUrl     String?
  seasons     Season[]
  matches     Match[]
  standings   StandingRow[]
  newsItems   NewsItem[]
  trophies    Trophy[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Season {
  id            String      @id @default(cuid())
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id])
  yearStart     Int
  yearEnd       Int
  matches       Match[]
  standings     StandingRow[]
  squads        TeamSquad[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([competitionId])
}

model Team {
  id          String   @id @default(cuid())
  providerKey String?  @unique
  name        String
  country     String?
  badgeUrl    String?
  venue       String?
  coachName   String?
  squads      TeamSquad[]
  standings   StandingRow[]
  homeMatches Match[]  @relation("HomeTeam")
  awayMatches Match[]  @relation("AwayTeam")
  trophies    Trophy[]
  currentPlayers       Player[]
  events               MatchEvent[]
  lineups              MatchLineup[]
  teamNewsItems        TeamNewsItem[]
  newsItems            NewsItem[]
  notificationPrefs    NotificationPref[]
  transfersFrom        Transfer[] @relation("TransferFrom")
  transfersTo          Transfer[] @relation("TransferTo")
  loanedContractsFrom  PlayerContract[] @relation("LoanFromTeam")
  contracts            PlayerContract[]
  marketValues         MarketValueSnapshot[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Player {
  id              String   @id @default(cuid())
  providerKey     String?  @unique
  name            String
  dob             DateTime?
  nationality     String?
  birthCountry    String?
  photoUrl        String?
  preferredFoot   String?
  position        String?
  heightCm        Int?
  currentTeamId   String?
  currentTeam     Team?    @relation(fields: [currentTeamId], references: [id])
  squads          TeamSquad[]
  transfers       Transfer[]
  events          MatchEvent[]
  lineups         MatchLineup[]
  newsItems       NewsItem[]
  contracts       PlayerContract[]
  marketValues    MarketValueSnapshot[]
  playerAgents    PlayerAgent[]
  valueQuizAttempts ValueQuizAttempt[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([currentTeamId])
  @@index([nationality])
  @@index([position])
}

model Agent {
  id        String   @id @default(cuid())
  name      String
  country   String?
  email     String?
  phone     String?
  agencyMemberships AgentAgencyMembership[]
  playerAgents      PlayerAgent[]
  contracts         PlayerContract[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Agency {
  id        String   @id @default(cuid())
  name      String   @unique
  country   String?
  website   String?
  agents    AgentAgencyMembership[]
  playerAgents PlayerAgent[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model AgentAgencyMembership {
  id        String   @id @default(cuid())
  agentId   String
  agencyId  String
  role      String?
  startDate DateTime?
  endDate   DateTime?

  agent  Agent  @relation(fields: [agentId], references: [id])
  agency Agency @relation(fields: [agencyId], references: [id])

  @@unique([agentId, agencyId])
  @@index([agencyId])
}

model PlayerAgent {
  id         String   @id @default(cuid())
  playerId   String
  agentId    String?
  agencyId   String?
  startDate  DateTime?
  endDate    DateTime?

  player Player @relation(fields: [playerId], references: [id])
  agent  Agent?  @relation(fields: [agentId], references: [id])
  agency Agency? @relation(fields: [agencyId], references: [id])

  @@index([playerId])
  @@index([agentId])
  @@index([agencyId])
}

model PlayerContract {
  id             String   @id @default(cuid())
  playerId       String
  clubId         String?
  startDate      DateTime
  endDate        DateTime
  isOnLoan       Boolean  @default(false)
  loanFromTeamId String?
  status         ContractStatus
  wageEur        Float?
  releaseClauseEur Float?
  extensionOptionDate DateTime?
  agentId        String?

  player   Player @relation(fields: [playerId], references: [id])
  club     Team?  @relation(fields: [clubId], references: [id])
  loanFrom Team?  @relation("LoanFromTeam", fields: [loanFromTeamId], references: [id])
  agent    Agent? @relation(fields: [agentId], references: [id])

  @@index([endDate])
  @@index([status])
  @@index([clubId])
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
  OPTION
}

model MarketValueSnapshot {
  id        String   @id @default(cuid())
  playerId  String?
  teamId    String?
  date      DateTime
  valueEur  Int
  currency  String   @default("EUR")
  source    String?
  note      String?

  player Player? @relation(fields: [playerId], references: [id])
  team   Team?   @relation(fields: [teamId], references: [id])

  @@index([date])
  @@index([playerId, date])
  @@index([teamId, date])
  @@index([valueEur])
}

model ForumCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  threads     ForumThread[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ForumThread {
  id            String   @id @default(cuid())
  categoryId    String
  title         String
  authorId      String?
  isRumour      Boolean  @default(false)
  relatedClubId String?
  relatedPlayerId String?
  posts         ForumPost[]
  subscriptions ForumThreadSubscription[]
  tags          ForumTagOnThread[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category ForumCategory @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([relatedClubId])
  @@index([relatedPlayerId])
}

model ForumPost {
  id        String   @id @default(cuid())
  threadId  String
  authorId  String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread ForumThread @relation(fields: [threadId], references: [id])

  @@index([threadId])
  @@index([createdAt])
}

model ForumThreadSubscription {
  id        String   @id @default(cuid())
  threadId  String
  userId    String
  createdAt DateTime @default(now())

  thread ForumThread @relation(fields: [threadId], references: [id])
  user   User        @relation(fields: [userId], references: [id])

  @@unique([threadId, userId])
  @@index([userId])
}

model ForumTag {
  id    String   @id @default(cuid())
  name  String   @unique
  slug  String   @unique
  threads ForumTagOnThread[]
}

model ForumTagOnThread {
  threadId String
  tagId    String

  thread ForumThread @relation(fields: [threadId], references: [id])
  tag    ForumTag    @relation(fields: [tagId], references: [id])

  @@id([threadId, tagId])
}

model ValueQuizAttempt {
  id        String   @id @default(cuid())
  userId    String?
  playerId  String
  guessedValueEur Int
  actualValueEur  Int
  deltaEur        Int
  createdAt DateTime @default(now())

  user   User?  @relation(fields: [userId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  @@index([playerId])
  @@index([createdAt])
}

model TeamSquad {
  id       String @id @default(cuid())
  teamId   String
  seasonId String
  playerId String
  role     String?
  shirtNo  Int?

  team   Team   @relation(fields: [teamId], references: [id])
  season Season @relation(fields: [seasonId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  @@unique([teamId, seasonId, playerId])
  @@index([teamId, seasonId])
}

model Match {
  id            String       @id @default(cuid())
  providerKey   String?      @unique
  seasonId      String?
  season        Season?      @relation(fields: [seasonId], references: [id])
  competitionId String?
  competition   Competition? @relation(fields: [competitionId], references: [id])

  kickoff    DateTime
  status     String   @default("SCHEDULED")
  homeTeamId String
  awayTeamId String
  homeTeam   Team @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team @relation("AwayTeam", fields: [awayTeamId], references: [id])

  homeScore Int? @default(0)
  awayScore Int? @default(0)

  venue     String?
  statsJson String?

  events  MatchEvent[]
  lineups MatchLineup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kickoff])
  @@index([homeTeamId])
  @@index([awayTeamId])
}

model MatchEvent {
  id       String  @id @default(cuid())
  matchId  String
  minute   Int?
  type     String
  teamId   String?
  playerId String?
  assistId String?
  metaJson String?

  match  Match  @relation(fields: [matchId], references: [id])
  team   Team?  @relation(fields: [teamId], references: [id])
  player Player? @relation(fields: [playerId], references: [id])

  @@index([matchId])
}

model MatchLineup {
  id         String @id @default(cuid())
  matchId    String
  teamId     String
  playerId   String
  isStarting Boolean @default(false)
  inMin      Int?
  outMin     Int?
  rating     Float?
  cardsJson  String?
  g_aJson    String?

  match  Match  @relation(fields: [matchId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  @@index([matchId, teamId])
  @@index([playerId])
}

model StandingRow {
  id            String   @id @default(cuid())
  competitionId String
  seasonId      String?
  teamId        String
  position      Int
  played        Int
  won           Int
  drawn         Int
  lost          Int
  goalsFor      Int
  goalsAgainst  Int
  goalDiff      Int
  points        Int
  form          String?

  competition Competition @relation(fields: [competitionId], references: [id])
  season      Season?     @relation(fields: [seasonId], references: [id])
  team        Team        @relation(fields: [teamId], references: [id])

  @@index([competitionId, seasonId])
}

model NewsItem {
  id            String     @id @default(cuid())
  scope         String     @default("LATEST")
  title         String
  summary       String?
  source        String?
  url           String?
  imageUrl      String?
  publishedAt   DateTime   @default(now())
  competitionId String?
  teamId        String?
  playerId      String?

  competition Competition? @relation(fields: [competitionId], references: [id])
  team        Team?        @relation(fields: [teamId], references: [id])
  player      Player?      @relation(fields: [playerId], references: [id])

  @@index([publishedAt, scope])
  @@index([scope])
  @@index([competitionId])
  @@index([teamId])
}

model Transfer {
  id          String    @id @default(cuid())
  providerKey String?   @unique
  playerId    String
  fromTeamId  String?
  toTeamId    String?
  type        String
  fee         String?
  date        DateTime?
  metaJson    String?
  createdAt   DateTime  @default(now())

  player   Player @relation(fields: [playerId], references: [id])
  fromTeam Team?  @relation("TransferFrom", fields: [fromTeamId], references: [id])
  toTeam   Team?  @relation("TransferTo", fields: [toTeamId], references: [id])

  @@index([playerId])
  @@index([createdAt])
}

model Trophy {
  id            String   @id @default(cuid())
  teamId        String
  competitionId String?
  seasonLabel   String?
  count         Int @default(1)

  team        Team         @relation(fields: [teamId], references: [id])
  competition Competition? @relation(fields: [competitionId], references: [id])

  @@index([teamId])
}

model TeamNewsItem {
  id          String   @id @default(cuid())
  teamId      String
  title       String
  source      String?
  url         String?
  imageUrl    String?
  publishedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id])

  @@index([teamId, publishedAt])
}

model Follow {
  id          String          @id @default(cuid())
  userId      String
  entityType  String
  entityId    String
  createdAt   DateTime        @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, entityType, entityId])
  @@index([userId])
}

model NotificationPref {
  id         String  @id @default(cuid())
  userId     String
  teamId     String?
  matchStart Boolean @default(true)
  goals      Boolean @default(true)
  redCards   Boolean @default(true)
  finalScore Boolean @default(true)
  transfers  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  team Team? @relation(fields: [teamId], references: [id])

  @@unique([userId, teamId])
}

model PushSubscription {
  id        String @id @default(cuid())
  userId    String
  endpoint  String @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model FantasyTeam {
  id          String   @id @default(cuid())
  userId      String   @unique
  squadJson   String   // JSON array of player slots
  budget      Float    @default(100.0)
  teamName    String   @default("My Fantasy XI")
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model MatchPrediction {
  id           String   @id @default(cuid())
  userId       String
  matchId      String
  homeGoals    Int
  awayGoals    Int
  confidence   Int      @default(3)
  outcome      String   // "home" | "draw" | "away"
  correct      Boolean?
  pointsEarned Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, matchId])
  @@index([userId])
  @@index([matchId])
}
